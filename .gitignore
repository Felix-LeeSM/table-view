# Claude Code sub-agent git worktrees. Untracked by design — also gitignored so
# Tailwind v4's `@tailwindcss/vite` source-scanner (which respects .gitignore)
# doesn't walk into them and resolve sibling `<img src="...">` paths against
# stale worktree roots.
.claude/worktrees/
# Multi-agent / multi-brain worktrees (Claude / Codex / Cursor 공통, platform-neutral).
# `scripts/worktree-spawn.sh` 가 생성. sprint-387 lock.
worktrees/

# Test
coverage/
# Anchor `wdio-report/` to the repo root so the e2e bind-mount target
# (`e2e/wdio-report/`) can preserve its `.gitkeep` (sprint-169 Sprint 4).
/wdio-report/
e2e/wdio-report/*
!e2e/wdio-report/.gitkeep
test-results/

