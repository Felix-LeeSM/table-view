.startup-trials/

# Icon build artifacts — partial-info.plist is regenerated by actool on every
# `pnpm icons:build`. The .car/.icns siblings ARE committed (so dev/CI builds
# don't require local Xcode + librsvg). Re-running build-icons.sh refreshes them.
src-tauri/icons/Compiled/partial-info.plist