{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.env)|Edit(*.env.*)|Write(*.env)|Write(*.env.*)",
            "command": "echo 'BLOCKED: Editing .env files is not allowed. Use .env.local for local overrides.' >&2 && exit 1"
          },
          {
            "type": "command",
            "if": "Edit(*.claude/settings.local.json)|Write(*.claude/settings.local.json)",
            "command": "echo 'BLOCKED: Editing local settings is not allowed.' >&2 && exit 1"
          },
          {
            "type": "command",
            "if": "Edit(memory/decisions/*/memory.md)|Write(memory/decisions/*/memory.md)",
            "command": "echo '⚠️  ADR 본문은 작성 순간 동결입니다. 결정/이유/트레이드오프 본문을 수정하지 마세요. 갱신 가능한 것은 프론트매터 메타 필드(status, superseded_by)뿐입니다. 결정을 뒤집으려면 새 ADR을 추가하세요.' >&2"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.rs)|Write(*.rs)",
            "command": "cd \"$CLAUDE_PROJECT_DIR\"/src-tauri && cargo fmt 2>/dev/null || true",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*.ts)|Edit(*.tsx)|Write(*.ts)|Write(*.tsx)",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npx prettier --write $(echo \"$TOOL_INPUT\" | jq -r '.file_path' | sed \"s|^$CLAUDE_PROJECT_DIR/||\") 2>/dev/null || true",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Edit(memory/**)|Write(memory/**)",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bash scripts/check-memory-size.sh 2>&1 | head -10 || true",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Edit(memory/**)|Write(memory/**)",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bash scripts/check-memory-structure.sh 2>&1 | head -10 || true",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Edit(memory/decisions/**)|Write(memory/decisions/**)",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bash scripts/check-memory-adr.sh 2>&1 | head -30 || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Table View 작업 완료\" with title \"Claude Code\"' 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
