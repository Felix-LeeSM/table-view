{
  "name": "table-view",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" package.json .prettierrc \"src-tauri/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" package.json .prettierrc \"src-tauri/**/*.json\"",
    "format:docs": "prettier --write README.md CLAUDE.md \"docs/**/*.md\" \".claude/**/*.md\"",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "test": "vitest run",
    "contrast:check": "tsx scripts/check-theme-contrast.ts",
    "test:docker": "docker compose -f docker-compose.test.yml up -d && ./scripts/wait-for-test-db.sh && cd src-tauri && cargo test --test schema_integration --test query_integration; cd .. && docker compose -f docker-compose.test.yml down",
    "test:e2e": "wdio run wdio.conf.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-shell": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.3",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/types": "^9.27.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^29.0.2",
    "lefthook": "2.1.5",
    "prettier": "^3.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.3",
    "webdriverio": "^9.27.0"
  },
  "packageManager": "pnpm@10.20.0"
}
