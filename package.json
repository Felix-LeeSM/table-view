{
  "name": "table-view",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.20.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsx scripts/check-eslint-static-policy.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" package.json .prettierrc \"src-tauri/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" package.json .prettierrc \"src-tauri/**/*.json\"",
    "format:docs": "prettier --write README.md CLAUDE.md \"docs/**/*.md\" \".claude/**/*.md\"",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "build:sql-wasm": "cd src-tauri/sql-parser-core && wasm-pack build --target web --out-dir ../../src/lib/sql/wasm --features wasm && cd ../.. && tsx scripts/reset-sql-wasm-gitignore.ts",
    "build:mongosh-wasm": "cd src-tauri/mongosh-parser-core && wasm-pack build --target web --out-dir ../../src/lib/mongo/wasm --features wasm && cd ../.. && tsx scripts/reset-mongosh-wasm-gitignore.ts",
    "wasm:size": "bash scripts/check-wasm-size.sh",
    "docs:links": "tsx scripts/check-doc-links.ts",
    "test": "vitest run",
    "contrast:check": "tsx scripts/check-theme-contrast.ts",
    "build:e2e": "vite build --mode e2e --minify=false",
    "test:e2e": "wdio run wdio.smoke.conf.ts",
    "test:e2e:smoke": "wdio run wdio.smoke.conf.ts",
    "tauri": "tauri",
    "icons:build": "./scripts/build-icons.sh",
    "db:up": "docker compose up -d && ./scripts/db/wait.sh",
    "db:down": "docker compose down -v",
    "db:seed": "tsx scripts/fixtures/index.ts seed",
    "db:reset": "tsx scripts/fixtures/index.ts reset",
    "db:connections": "tsx scripts/fixtures/index.ts connections",
    "db:generate": "tsx scripts/fixtures/index.ts generate",
    "fixtures:start": "docker compose up -d && ./scripts/db/wait.sh",
    "fixtures:stop": "docker compose down -v",
    "fixtures:load": "tsx scripts/fixtures/index.ts load",
    "fixtures:rebuild": "tsx scripts/fixtures/index.ts rebuild",
    "fixtures:preview": "tsx scripts/fixtures/index.ts preview",
    "fixtures:register-connections": "tsx scripts/fixtures/index.ts register-connections",
    "fixtures:clear-connections": "tsx scripts/fixtures/index.ts clear-connections"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "i18next": "^26.3.3",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^10.4.0",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "^12.3.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.3",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/types": "^9.27.0",
    "better-sqlite3": "^12.10.0",
    "duckdb": "^1.4.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "ioredis": "^5.10.1",
    "jsdom": "^29.0.2",
    "lefthook": "2.1.5",
    "mongodb": "^7.2.0",
    "mssql": "^12.5.4",
    "mysql2": "^3.11.0",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.3",
    "webdriverio": "^9.27.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.20.0"
}
