# Copy to .env (or export in your shell) and uncomment lines whose default
# ports conflict with locally running services. docker compose auto-loads .env.
#
# Naming follows each client's standard env var convention:
#   PostgreSQL  — libpq   (PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE)
#   MySQL       — client  (MYSQL_HOST, MYSQL_TCP_PORT, MYSQL_USER, MYSQL_PWD)
#   MongoDB/ES/Redis — no standard port env; project-local names used
#
# Consumed by:
#   - docker-compose.yml         (dev DB + e2e profile)
#   - scripts/wait-for-test-db.sh
#   - src-tauri/tests/common/mod.rs
#
# E2E test profile entrypoint:
#   pnpm test:e2e:docker  →  docker compose --profile test up --build \
#                             --abort-on-container-exit --exit-code-from e2e
#   The `e2e` service runs `e2e/run-e2e-docker.sh` inside table-view-e2e:local
#   against the `postgres` and `mongo` services on the compose network.

# ---- PostgreSQL (dev + e2e profile) ----
# default user/password는 `testuser`/`testpass` — 같은 한 쌍을 CI workflow,
# Rust 통합 테스트(`src-tauri/tests/common/mod.rs`), e2e UI 폼
# (`e2e/_helpers.ts`), `scripts/wait-for-test-db.sh`가 전부 사용한다.
# drift는 e2e 인증 실패로 spec 다수가 도미노로 무너지는 결과를 낸다 (2026-05-01).
PGPORT=15432
# PGUSER=testuser
# PGPASSWORD=testpass
# PGDATABASE=table_view_test

# ---- MongoDB (e2e profile) ----
# MONGO_USER and MONGO_PASSWORD seed both the mongo:7 root credentials AND
# the e2e container's E2E_MONGO_* env, so they MUST stay in lock-step. The
# e2e/connection-switch.spec.ts hardcodes "testuser"/"testpass" — drift is
# treated as a build error, not a silent skip.
# MONGO_USER=testuser
# MONGO_PASSWORD=testpass
MONGO_PORT=27018

# ---- Reservations for future test profiles (mysql / es / redis) ----
# These are documented for future tooling that may reintroduce the deleted
# docker-compose.test.yml services. Currently unused by any committed
# compose file; safe to leave commented out.
MYSQL_TCP_PORT=13306
ES_PORT=19200
REDIS_PORT=16379
