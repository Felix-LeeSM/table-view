#!/bin/sh
# Tracked git hook wrapper — `core.hooksPath = .githooks` 가 활성화되면 git 가
# `.git/hooks/` 대신 이 스크립트를 직접 호출한다.
#
# 책임은 단 하나: lefthook 이 PATH 에 있는지 확인하고 위임. 없으면 명확하게
# 실패시켜 setup.sh 를 안내한다. 부트스트랩 미실행 상태로 commit 이 슬그머니
# 통과하는 silent-pass 회귀를 막기 위함.
#
# `"$@"` 는 git 가 hook 에 넘긴 인자(이 hook 은 인자 없음)와 stdin 을
# 그대로 전달. 일관성을 위해 모든 wrapper 가 같은 패턴.

set -e

# mise shim fallback — 사용자가 IDE (VSCode 등) 에서 git commit 을 호출할 때
# 부모 프로세스 PATH 에 mise activate 결과가 없을 수 있다. shims 디렉토리가
# 존재하면 명시적으로 prepend 해서 PATH 동기화 비대칭을 흡수한다.
if [ -d "$HOME/.local/share/mise/shims" ]; then
  PATH="$HOME/.local/share/mise/shims:$PATH"
  export PATH
fi

if ! command -v lefthook >/dev/null 2>&1; then
  echo "ERROR: lefthook 이 PATH 에 없습니다." >&2
  echo "       먼저 'bash scripts/setup.sh' 를 실행하세요." >&2
  exit 1
fi

# `--no-auto-install` — 우리는 `core.hooksPath = .githooks` 로 git 의 hook
# 디렉토리를 옮겼다. lefthook 의 기본 동작은 매 실행마다 `.git/hooks/` 에
# 자체 stub 을 sync 하려 시도하는데, core.hooksPath 가 다른 곳을 가리키면
# "skip sync" 경고를 띄운다. 우리에게 sync 는 영영 불필요하므로 명시적으로
# 끈다.
exec lefthook run pre-commit --no-auto-install "$@"
