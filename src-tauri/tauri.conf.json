{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Table View",
  "version": "0.4.1",
  "identifier": "com.tableview.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "launcher",
        "title": "Table View",
        "width": 720,
        "height": 560,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "visible": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com; object-src 'none'; base-uri 'self'; frame-src 'none'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Felix-LeeSM/table-view/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwQjQ0QzM1NDFBRTkyOUEKUldTYWtxNUJOVXkwNENrZm9sa2RSdzgvWXVjb0U2WU9RbkNtV3pKNnBSMkRoYnF4ZEdqcmFMc08K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/Compiled/Assets.car": "Assets.car",
      "icons/Compiled/AppIcon.icns": "AppIcon.icns"
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
